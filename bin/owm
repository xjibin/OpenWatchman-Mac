#!/usr/bin/env bash
#
# owm — OpenWatchman command-line interface.
#
# A thin, human-facing front-end over the sorter engine (openwatchman.sh).
# The background launchd agent calls the engine directly and stays silent;
# this banner and all CLI output are for interactive use only.
#
# Installed under the friendly name "openwatch" (with "owm" as a short alias).
# It refers to itself by whatever name it was invoked as.

set -u

PROG="$(basename -- "$0")"
LABEL="com.openwatchman.agent"
WATCH_DIR="${OPENWATCHMAN_DIR:-$HOME/Downloads}"
MARKER="$WATCH_DIR/.openwatchman-baseline"
LOG="$HOME/Library/Logs/openwatchman.log"
ERRLOG="$HOME/Library/Logs/openwatchman.err.log"
APP="$HOME/Applications/OpenWatchman.app"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
STATE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/openwatchman"
JOURNAL="$STATE_DIR/journal.tsv"   # move journal the engine writes; 'undo' reads it
CONFIG="$STATE_DIR/config"         # optional key=value settings (never sourced)
PAUSE="$STATE_DIR/paused"          # expiry epoch; 0 = paused until resumed
REPO_CONF="$STATE_DIR/repo"
REPO_URL="https://github.com/xjibin/OpenWatchman-Mac.git"
TAB=$'\t'

# --- resolve where this script lives (portable; macOS has no readlink -f) ---
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# --- find the engine: next to us (repo) or installed ------------------------
ENGINE=""
for c in "$SELF_DIR/openwatchman.sh" "$HOME/.local/bin/openwatchman.sh"; do
  if [ -x "$c" ]; then ENGINE="$c"; break; fi
done

# --- colors only on a terminal ----------------------------------------------
if [ -t 1 ]; then B=$'\033[36m'; D=$'\033[2m'; Y=$'\033[33m'; G=$'\033[32m'; N=$'\033[0m'
else B=""; D=""; Y=""; G=""; N=""; fi

banner() {
  printf '%s' "$B"
  cat <<'ART'
   ____               __          __   _       _                           
  / __ \              \ \        / /  | |     | |                          
 | |  | |_ __   ___ _ _\ \  /\  / /_ _| |_ ___| |__  _ __ ___   __ _ _ __  
 | |  | | '_ \ / _ \ '_ \ \/  \/ / _` | __/ __| '_ \| '_ ` _ \ / _` | '_ \ 
 | |__| | |_) |  __/ | | \  /\  / (_| | || (__| | | | | | | | | (_| | | | |
  \____/| .__/ \___|_| |_|\/  \/ \__,_|\__\___|_| |_|_| |_| |_|\__,_|_| |_|
        | |                                                                
        |_|
ART
  printf '%s' "$N"
  printf '%s  Sort new downloads & screenshots into Year/Month folders.%s\n\n' "$D" "$N"
}

version() {
  local v=""
  [ -n "$ENGINE" ] && v="$(grep -m1 '^VERSION=' "$ENGINE" | cut -d'"' -f2)"
  echo "OpenWatchman ${v:-unknown}"
}

usage() {
  banner
  cat <<EOF
Usage: $PROG <command>

  status     installed? loaded? paused? baseline date, recent activity
  preview    dry-run — what would move right now (moves nothing)
  sweep      dry-run a full one-time reconcile; '$PROG sweep --apply' runs it
  run        trigger the agent to do a pass now
  undo       show what the last run moved; '$PROG undo --apply' puts it back
  pause      suspend sorting — '$PROG pause 2h' for a while, bare for until-resumed
  resume     re-enable sorting after a pause
  config     show settings; '$PROG config min_age 1h' sets one
  logs       recent log lines ('$PROG logs -f' to follow)
  doctor     diagnostics, incl. a Full Disk Access hint
  update     git pull your clone and install the refreshed scripts here
  version    print version
  help       this help

Watched folder: $WATCH_DIR   (override with OPENWATCHMAN_DIR)
EOF
}

need_macos() {
  [ "$(uname -s)" = "Darwin" ] || { echo "$PROG: macOS only." >&2; exit 1; }
}
require_engine() {
  [ -n "$ENGINE" ] || {
    echo "$PROG: sorter engine not found (expected ~/.local/bin/openwatchman.sh). Run ./install.sh first." >&2
    exit 1; }
}
loaded() { launchctl print "gui/$(id -u)/$LABEL" >/dev/null 2>&1; }
baseline_date() {
  [ -f "$MARKER" ] || { echo "none"; return; }
  date -r "$(cat "$MARKER" 2>/dev/null)" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unreadable"
}

# parse a duration — bare seconds or <n>s/m/h/d — into seconds on stdout.
# Fails on anything else. (Kept byte-identical with the copy in
# bin/openwatchman.sh — update both together.)
parse_duration() {
  local v="$1" n mult
  case "$v" in ''|*[!0-9smhd]*) return 1 ;; esac
  case "$v" in
    *s) n="${v%s}"; mult=1 ;;
    *m) n="${v%m}"; mult=60 ;;
    *h) n="${v%h}"; mult=3600 ;;
    *d) n="${v%d}"; mult=86400 ;;
    *)  n="$v";     mult=1 ;;
  esac
  case "$n" in ''|*[!0-9]*) return 1 ;; esac
  echo $(( 10#$n * mult ))
}

# read the config file into CFG_* vars — whitelisted keys only, never sourced
CFG_MIN_AGE=""
CFG_ON_DUPLICATE=""
read_config() {
  CFG_MIN_AGE=""
  CFG_ON_DUPLICATE=""
  [ -f "$CONFIG" ] || return 0
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      min_age=*)      CFG_MIN_AGE="${line#min_age=}" ;;
      on_duplicate=*) CFG_ON_DUPLICATE="${line#on_duplicate=}" ;;
    esac
  done < "$CONFIG"
  return 0
}

# echo "<effective value> <provenance>" for a key, resolving exactly the way
# the engine does: environment beats config beats default; invalid -> default.
setting_of() {
  local key="$1" raw="" src="default" secs
  case "$key" in
    min_age)
      if [ -n "${OPENWATCHMAN_MIN_AGE:-}" ]; then raw="$OPENWATCHMAN_MIN_AGE"; src="env"
      elif [ -n "$CFG_MIN_AGE" ]; then raw="$CFG_MIN_AGE"; src="config"; fi
      if [ -n "$raw" ] && secs="$(parse_duration "$raw")" && [ -n "$secs" ]; then
        echo "$raw $src"
      else
        echo "0 default"
      fi
      ;;
    on_duplicate)
      if [ -n "${OPENWATCHMAN_ON_DUPLICATE:-}" ]; then raw="$OPENWATCHMAN_ON_DUPLICATE"; src="env"
      elif [ -n "$CFG_ON_DUPLICATE" ]; then raw="$CFG_ON_DUPLICATE"; src="config"; fi
      case "$raw" in
        rename|skip|trash) echo "$raw $src" ;;
        *) echo "rename default" ;;
      esac
      ;;
  esac
}

# echo a human description of an ACTIVE pause; fail if not (or no longer) paused
pause_state() {
  [ -f "$PAUSE" ] || return 1
  local ep
  ep="$(cat "$PAUSE" 2>/dev/null)"
  case "$ep" in ''|*[!0-9]*) ep=0 ;; esac   # unreadable = engine stays paused
  if [ "$ep" -eq 0 ]; then
    echo "paused indefinitely"
  elif [ "$ep" -gt "$(date +%s)" ]; then
    echo "paused until $(date -r "$ep" '+%Y-%m-%d %H:%M')"
  else
    return 1    # expired — the engine clears the flag on its next run
  fi
}

# is $1 a git checkout of the OpenWatchman-Mac repo?
is_repo() {
  [ -n "${1:-}" ] || return 1
  [ -d "$1/.git" ] || return 1
  [ -f "$1/bin/openwatchman.sh" ] && [ -f "$1/bin/owm" ] || return 1
  case "$(git -C "$1" remote get-url origin 2>/dev/null)" in
    *xjibin/OpenWatchman-Mac*) return 0 ;;
    *) return 1 ;;
  esac
}

cmd_status() {
  need_macos
  banner
  if loaded; then echo "${G}●${N} agent loaded  ($LABEL)"; else echo "${Y}○${N} agent not loaded — run ./install.sh"; fi
  if pstate="$(pause_state)"; then
    echo "${Y}‖${N} $pstate — '$PROG resume' to re-enable sorting"
  fi
  echo "  watched : $WATCH_DIR"
  echo "  baseline: $(baseline_date)  (only files added after this are eligible)"
  echo "  recent activity:"
  if [ -f "$LOG" ]; then tail -n 5 "$LOG" | sed 's/^/    /'; else echo "    (no log yet)"; fi
}

cmd_preview() {
  need_macos; require_engine
  echo "${D}Preview (nothing will move):${N}"
  "$ENGINE" --dry-run
}

cmd_sweep() {
  need_macos; require_engine
  if [ "${1:-}" = "--apply" ]; then
    echo "${Y}This sorts/relocates EVERY eligible file, including ones from before install.${N}"
    printf "Proceed? [y/N] "; read -r a
    case "$a" in y|Y) ;; *) echo "aborted."; exit 1 ;; esac
    OPENWATCHMAN_BASELINE=1 "$ENGINE"
    echo "Done — see '$PROG logs'."
  else
    echo "${D}Full one-time reconcile, DRY RUN (baseline ignored, nothing moves):${N}"
    OPENWATCHMAN_BASELINE=1 "$ENGINE" --dry-run
    echo
    echo "If that looks right, apply it with:  $PROG sweep --apply"
  fi
}

cmd_run() {
  need_macos
  if loaded && launchctl kickstart -k "gui/$(id -u)/$LABEL" 2>/dev/null; then
    echo "Triggered a run. Check '$PROG logs'."
  else
    echo "$PROG: couldn't trigger the agent (is it loaded? try ./install.sh)." >&2
    exit 1
  fi
}

cmd_logs() {
  [ -f "$LOG" ] || { echo "No log yet at $LOG"; exit 0; }
  if [ "${1:-}" = "-f" ]; then tail -f "$LOG"; else tail -n 20 "$LOG"; fi
}

# --- undo: read the engine's move journal and reverse the last sorting run ---
# The journal is TSV: epoch, run id, verb, source, destination. Verbs 'moved'
# and 'relocated' are undoable; 'undone' records a past restore; a line with
# verb 'unjournalable' stands in for a move whose paths couldn't be journaled.

# journal line $1 recorded src -> dst; was it reversed by a LATER 'undone' line?
move_was_undone() {
  local i="$1" k
  k=$((i + 1))
  while [ "$k" -lt "$jn" ]; do
    if [ "${j_verb[k]}" = "undone" ] \
       && [ "${j_src[k]}" = "${j_dst[i]}" ] && [ "${j_dst[k]}" = "${j_src[i]}" ]; then
      return 0
    fi
    k=$((k + 1))
  done
  return 1
}

cmd_undo() {
  need_macos
  local apply=0
  case "${1:-}" in
    "")      ;;
    --apply) apply=1 ;;
    *) echo "$PROG: unknown option for undo: $1 (try '$PROG undo' or '$PROG undo --apply')" >&2; exit 1 ;;
  esac

  if [ ! -s "$JOURNAL" ]; then
    echo "Nothing to undo — no moves journaled yet. (The journal appears at"
    echo "$JOURNAL after the first sorted file.)"
    exit 0
  fi

  # load the journal into parallel arrays (bash 3.2 — no mapfile)
  j_rid=(); j_verb=(); j_src=(); j_dst=()
  jn=0
  local rid verb src dst
  while IFS="$TAB" read -r _ rid verb src dst; do
    [ -n "$verb" ] || continue
    j_rid[jn]="$rid"; j_verb[jn]="$verb"; j_src[jn]="$src"; j_dst[jn]="$dst"
    jn=$((jn + 1))
  done < "$JOURNAL"

  # the target run: newest moved/relocated line not already reversed by an
  # undo (runs that are only 'undone'/'unjournalable' are never targets)
  local target="" i
  i=$((jn - 1))
  while [ "$i" -ge 0 ]; do
    case "${j_verb[i]}" in
      moved|relocated)
        if ! move_was_undone "$i"; then target="${j_rid[i]}"; break; fi ;;
    esac
    i=$((i - 1))
  done
  if [ -z "$target" ]; then
    echo "Nothing to undo — every journaled move has already been restored."
    exit 0
  fi

  # collect that run's still-standing moves, in journal (= move) order
  sel=()
  local sn=0
  i=0
  while [ "$i" -lt "$jn" ]; do
    if [ "${j_rid[i]}" = "$target" ]; then
      case "${j_verb[i]}" in
        moved|relocated)
          if ! move_was_undone "$i"; then sel[sn]="$i"; sn=$((sn + 1)); fi ;;
      esac
    fi
    i=$((i + 1))
  done

  local when run_ep undo_run=""
  run_ep="${target%%.*}"
  when="$(date -r "$run_ep" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "?")"
  if [ "$apply" -eq 1 ]; then
    undo_run="$(date +%s).$$"
    echo "Restoring the run from $when ($sn move(s), newest first):"
  else
    echo "${D}Undo plan for the run from $when ($sn move(s), newest first — DRY RUN):${N}"
  fi

  # walk newest-first, classify, and (only with --apply) restore
  local restorable=0 occupied=0 gone=0 restored=0 failed=0 k from to
  k=$((sn - 1))
  while [ "$k" -ge 0 ]; do
    i="${sel[k]}"
    src="${j_src[i]}"; dst="${j_dst[i]}"
    from="${dst#"$WATCH_DIR"/}"; to="${src#"$WATCH_DIR"/}"
    if [ ! -f "$dst" ]; then
      gone=$((gone + 1))
      echo "  skip     $from  ->  $to  ${D}(file moved since)${N}"
    elif [ -e "$src" ]; then
      occupied=$((occupied + 1))
      echo "  skip     $from  ->  $to  ${D}(original slot occupied)${N}"
    elif [ "$apply" -eq 1 ]; then
      mkdir -p "${src%/*}" 2>/dev/null
      if mv -n "$dst" "$src" 2>/dev/null; then
        restored=$((restored + 1))
        printf '%s\t%s\tundone\t%s\t%s\n' "$(date +%s)" "$undo_run" "$dst" "$src" >> "$JOURNAL"
        echo "$(date '+%F %T')  undone  ${dst##*/}  ->  $to" >> "$LOG" 2>/dev/null
        echo "  ${G}restored${N} $from  ->  $to"
      else
        failed=$((failed + 1))
        echo "  ${Y}FAILED${N}   $from  ->  $to"
      fi
    else
      restorable=$((restorable + 1))
      echo "  restore  $from  ->  $to"
    fi
    k=$((k - 1))
  done

  echo
  if [ "$apply" -eq 1 ]; then
    echo "Restored $restored of $sn; $occupied skipped (slot occupied), $gone skipped (moved since)."
    if [ "$failed" -gt 0 ]; then
      echo "$PROG: $failed restore(s) failed — see above." >&2
      exit 1
    fi
  else
    echo "$restorable restorable; $occupied would skip (slot occupied), $gone would skip (moved since)."
    if [ "$restorable" -gt 0 ]; then
      echo "Nothing was moved. Run '$PROG undo --apply' to restore."
    else
      echo "Nothing is restorable from this run — there is nothing to apply."
    fi
  fi
}

cmd_pause() {
  need_macos
  if [ "$#" -gt 1 ]; then
    echo "$PROG: usage: $PROG pause [DURATION]   (e.g. '$PROG pause 2h')" >&2
    exit 1
  fi
  local dur="${1:-}" secs until_ep
  mkdir -p "$STATE_DIR"
  if [ -z "$dur" ]; then
    printf '0\n' > "$PAUSE"
    echo "Sorting paused until resumed. Re-enable with '$PROG resume'."
    return 0
  fi
  if ! secs="$(parse_duration "$dur")"; then
    echo "$PROG: can't parse duration '$dur' — use bare seconds or <n>s/m/h/d (e.g. 30m, 2h, 1d)." >&2
    exit 1
  fi
  until_ep=$(( $(date +%s) + secs ))
  printf '%s\n' "$until_ep" > "$PAUSE"
  echo "Sorting paused until $(date -r "$until_ep" '+%Y-%m-%d %H:%M')."
}

cmd_resume() {
  if [ -f "$PAUSE" ]; then
    rm -f "$PAUSE"
    echo "Resumed — sorting is active again."
  else
    echo "Not paused — nothing to do."
  fi
}

cmd_config() {
  read_config
  local key="${1:-}" val="${2:-}" v tmp
  if [ "$#" -gt 2 ]; then
    echo "$PROG: usage: $PROG config [KEY [VALUE]]" >&2
    exit 1
  fi

  # no arguments: print every effective setting with its provenance
  if [ "$#" -eq 0 ]; then
    v="$(setting_of min_age)";      echo "min_age = ${v% *}  (${v#* })"
    v="$(setting_of on_duplicate)"; echo "on_duplicate = ${v% *}  (${v#* })"
    echo
    echo "${D}Config file: $CONFIG   ('$PROG config KEY VALUE' to change)${N}"
    return 0
  fi

  case "$key" in
    min_age|on_duplicate) ;;
    *) echo "$PROG: unknown config key: $key (known keys: min_age, on_duplicate)" >&2; exit 1 ;;
  esac

  # one argument: print that key's effective value
  if [ "$#" -eq 1 ]; then
    v="$(setting_of "$key")"
    echo "${v% *}"
    return 0
  fi

  # two arguments: validate, then rewrite the file keeping the other key
  case "$key" in
    min_age)
      if ! parse_duration "$val" >/dev/null; then
        echo "$PROG: invalid min_age '$val' — use bare seconds or <n>s/m/h/d (e.g. 90, 45m, 1h, 7d)." >&2
        exit 1
      fi ;;
    on_duplicate)
      case "$val" in
        rename|skip|trash) ;;
        *) echo "$PROG: invalid on_duplicate '$val' — use rename, skip, or trash." >&2; exit 1 ;;
      esac ;;
  esac
  mkdir -p "$STATE_DIR"
  # temp file next to the config so the final mv is an atomic rename
  tmp="$(mktemp "$CONFIG.XXXXXX")" || { echo "$PROG: mktemp failed." >&2; exit 1; }
  {
    if [ "$key" = "min_age" ]; then printf 'min_age=%s\n' "$val"
    elif [ -n "$CFG_MIN_AGE" ]; then printf 'min_age=%s\n' "$CFG_MIN_AGE"; fi
    if [ "$key" = "on_duplicate" ]; then printf 'on_duplicate=%s\n' "$val"
    elif [ -n "$CFG_ON_DUPLICATE" ]; then printf 'on_duplicate=%s\n' "$CFG_ON_DUPLICATE"; fi
  } > "$tmp"
  mv "$tmp" "$CONFIG"
  echo "$key = $val  (saved to $CONFIG)"
}

cmd_update() {
  need_macos
  command -v git >/dev/null 2>&1 || { echo "$PROG: git not found; can't update." >&2; exit 1; }

  repo=""
  # 1) path recorded at install time
  if [ -f "$REPO_CONF" ]; then
    saved="$(cat "$REPO_CONF" 2>/dev/null)"
    if is_repo "$saved"; then repo="$saved"; fi
  fi
  # 2) invoked from inside the clone (e.g. ./bin/owm update)
  if [ -z "$repo" ]; then
    up="$(cd "$SELF_DIR/.." 2>/dev/null && pwd)"
    if is_repo "$up"; then repo="$up"; fi
  fi
  # 3) short search of common locations
  if [ -z "$repo" ]; then
    for cand in "$HOME/OpenWatchman-Mac" "$HOME/Downloads/OpenWatchman-Mac" \
                "$HOME/MyClaudeProjects/OpenWatchman-Mac" "$HOME/Developer/OpenWatchman-Mac"; do
      if is_repo "$cand"; then repo="$cand"; break; fi
    done
  fi
  # 4) nothing found — offer to clone (opt-in)
  if [ -z "$repo" ]; then
    echo "$PROG update: couldn't find your OpenWatchman-Mac clone."
    dest="$HOME/OpenWatchman-Mac"
    printf "Clone it into %s now? [y/N] " "$dest"
    read -r a
    case "$a" in
      y|Y)
        git clone "$REPO_URL" "$dest" || { echo "$PROG update: clone failed." >&2; exit 1; }
        repo="$dest"
        ;;
      *)
        echo "No clone made. Run this once from inside your clone ( ./bin/owm update ),"
        echo "or clone it yourself:  git clone $REPO_URL"
        exit 1
        ;;
    esac
  fi

  # remember the location for next time
  mkdir -p "$(dirname "$REPO_CONF")" 2>/dev/null || true
  printf '%s\n' "$repo" > "$REPO_CONF" 2>/dev/null || true

  echo "Clone: $repo"
  old="$(grep -m1 '^VERSION=' "$repo/bin/openwatchman.sh" 2>/dev/null | cut -d'"' -f2)"
  before="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"

  echo "Pulling latest (fast-forward only)…"
  if ! git -C "$repo" pull --ff-only; then
    echo >&2
    echo "$PROG update: couldn't fast-forward — the clone has local commits or has diverged." >&2
    echo "Sort it out in $repo (start with 'git status'), then re-run '$PROG update'." >&2
    exit 1
  fi

  after="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"
  new="$(grep -m1 '^VERSION=' "$repo/bin/openwatchman.sh" 2>/dev/null | cut -d'"' -f2)"

  # copy engine + CLI into place (skip if the target already IS the repo file)
  mkdir -p "$HOME/.local/bin"
  if [ ! "$repo/bin/openwatchman.sh" -ef "$HOME/.local/bin/openwatchman.sh" ]; then
    cp "$repo/bin/openwatchman.sh" "$HOME/.local/bin/openwatchman.sh"
  fi
  if [ ! "$repo/bin/owm" -ef "$HOME/.local/bin/owm" ]; then
    cp "$repo/bin/owm" "$HOME/.local/bin/owm"
  fi
  chmod 755 "$HOME/.local/bin/openwatchman.sh" "$HOME/.local/bin/owm" 2>/dev/null || true
  [ -e "$HOME/.local/bin/openwatch" ] || ln -sf "$HOME/.local/bin/owm" "$HOME/.local/bin/openwatch"

  echo
  if [ -n "$before" ] && [ "$before" = "$after" ]; then
    echo "Already up to date at ${new:-unknown}."
  else
    echo "Updated ${old:-?} -> ${new:-?}."
    changed="$(git -C "$repo" diff --name-only "$before" "$after" 2>/dev/null || true)"
    case "$changed" in
      *install.sh*|*launchd/*|*assets/*)
        echo
        echo "${Y}Note:${N} this release also changed the app or LaunchAgent setup."
        echo "To apply that part too, run:  ( cd \"$repo\" && ./install.sh --keep-baseline )"
        ;;
    esac
  fi
}

cmd_doctor() {
  need_macos
  banner
  echo "Diagnostics:"
  ok()   { printf '  %s[ok]%s  %s\n' "$G" "$N" "$1"; }
  warn() { printf '  %s[!!]%s  %s\n' "$Y" "$N" "$1"; }
  if pstate="$(pause_state)"; then
    warn "$pstate — '$PROG resume' to re-enable sorting"
  else
    ok "not paused"
  fi
  if [ -n "$ENGINE" ]; then ok "engine: $ENGINE"; else warn "engine script not found"; fi
  if [ -d "$APP" ]; then ok "app wrapper present"; else warn "app wrapper missing ($APP)"; fi
  if [ -f "$PLIST" ]; then ok "LaunchAgent plist present"; else warn "plist missing ($PLIST)"; fi
  if loaded; then
    ok "agent loaded"
    launchctl print "gui/$(id -u)/$LABEL" 2>/dev/null | grep -E 'runs =|last exit code =' | sed 's/^ */        /'
  else
    warn "agent not loaded"
  fi
  if [ -f "$MARKER" ]; then ok "baseline marker present ($(baseline_date))"; else warn "baseline marker missing"; fi
  probe="$(find "$WATCH_DIR" -maxdepth 3 -type f ! -name '.*' 2>/dev/null | head -1)"
  if [ -z "$probe" ]; then
    ok "Spotlight check skipped (no files under $WATCH_DIR yet)"
  else
    da="$(mdls -name kMDItemDateAdded -raw "$probe" 2>/dev/null)"
    if [ -n "$da" ] && [ "$da" != "(null)" ]; then
      ok "Spotlight date-added available (kMDItemDateAdded probe on a real file)"
    else
      warn "Spotlight date-added is null for a sample file (will fall back to mtime)"
    fi
  fi
  if [ -f "$ERRLOG" ] && grep -qi 'operation not permitted' "$ERRLOG"; then
    warn "Full Disk Access looks MISSING — \"Operation not permitted\" is in the error log."
    echo "        Grant it to $APP in System Settings > Privacy & Security > Full Disk Access, then reload the agent."
  else
    ok "no Full Disk Access errors in the log"
  fi
  echo
  echo "${D}Tip: '$PROG preview' shows what would move now; download a file, then '$PROG logs'.${N}"
}

cmd="${1:-}"; if [ "$#" -gt 0 ]; then shift; fi
case "$cmd" in
  ""|help|-h|--help)      usage ;;
  version|-v|--version)   version ;;
  status)                 cmd_status ;;
  preview|dry-run)        cmd_preview ;;
  sweep)                  cmd_sweep "$@" ;;
  run)                    cmd_run ;;
  undo)                   cmd_undo "$@" ;;
  pause)                  cmd_pause "$@" ;;
  resume)                 cmd_resume ;;
  config)                 cmd_config "$@" ;;
  logs)                   cmd_logs "$@" ;;
  update)                 cmd_update ;;
  doctor)                 cmd_doctor ;;
  *) echo "$PROG: unknown command: $cmd" >&2; echo "Run '$PROG help'." >&2; exit 1 ;;
esac
